# Runtime mode. "memory" (default) runs rooms in-process with SSE.
# Production multi-instance deployments use PartyKit (PARTYKIT_HOST).
MB_MODE=memory

# Secret for guarding the external sweeper endpoint (/api/sweep) on Vercel / serverless cron
MB_SWEEP_SECRET=

# Realtime transport selection (memory or partykit)
NEXT_PUBLIC_MB_MODE=memory
PARTYKIT_HOST=
NEXT_PUBLIC_PARTYKIT_HOST=

