# Runtime mode. "memory" (default when Supabase vars are absent) runs rooms in-process
# with SSE realtime — single server, ideal for local dev. "supabase" uses Postgres +
# Supabase Realtime and is required for any multi-instance / Vercel deployment.
MB_MODE=memory

# Supabase (required for MB_MODE=supabase)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Secret for guarding the external sweeper endpoint (/api/sweep) on Vercel / serverless cron
MB_SWEEP_SECRET=

# Must match MB_MODE so the browser picks the right realtime transport.
NEXT_PUBLIC_MB_MODE=memory
